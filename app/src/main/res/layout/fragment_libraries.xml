<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_base">

    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:background="@color/bg_panel" android:paddingHorizontal="12dp"
        android:gravity="center_vertical">
        <EditText android:id="@+id/et_search" android:layout_width="0dp" android:layout_height="38dp"
            android:layout_weight="1" android:hint="Search libraries..." android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary" android:textSize="13sp"
            android:background="@drawable/input_bg" android:paddingHorizontal="10dp"
            android:inputType="text" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_add_url" android:layout_width="wrap_content" android:layout_height="38dp"
            android:text="+ URL" android:textSize="12sp" android:backgroundTint="@color/cyan"
            android:textColor="#000" style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_libraries"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:divider="@null"/>
</LinearLayout>
