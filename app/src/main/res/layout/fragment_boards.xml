<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:orientation="vertical">

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/bg_panel"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tab_select"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="Select Board"
            android:textColor="@color/cyan"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tab_import"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="boards.txt"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- SELECT TAB -->
    <LinearLayout
        android:id="@+id/layout_select"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_panel"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tv_current_board"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="● ESP32 Dev Module"
                android:textColor="@color/cyan"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_current_fqbn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="esp32:esp32:esp32"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_board_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="30 boards loaded"
                android:textColor="@color/text_dim"
                android:textSize="11sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@color/bg_surface"
            android:hint="Search boards..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="13sp" />

        <androidx.recyclerview.widget.RecyclerView xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/rv_boards"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
    </LinearLayout>

    <!-- IMPORT TAB -->
    <ScrollView
        android:id="@+id/layout_import"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@color/bg_panel"
                android:lineSpacingExtra="3dp"
                android:padding="12dp"
                android:text="Where to find boards.txt on your PC:\n\nWindows: %APPDATA%\\Arduino15\\packages\\esp32\\hardware\\esp32\\&lt;version&gt;\\boards.txt\n\nMac: ~/Library/Arduino15/packages/esp32/hardware/esp32/&lt;version&gt;/boards.txt\n\nCopy it to your phone then import, or paste contents below."
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_import_file"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@color/bg_surface"
                android:text="📂  Import boards.txt File"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="— OR PASTE CONTENTS —"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/et_boards_txt"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginBottom="8dp"
                android:background="@color/bg_surface"
                android:fontFamily="monospace"
                android:gravity="top|start"
                android:hint="Paste boards.txt content here..."
                android:inputType="textMultiLine"
                android:padding="10dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_apply_paste"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="6dp"
                android:backgroundTint="@color/cyan"
                android:text="Apply boards.txt"
                android:textColor="#000" />

            <Button
                android:id="@+id/btn_clear_import"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Clear (use built-in boards)"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
