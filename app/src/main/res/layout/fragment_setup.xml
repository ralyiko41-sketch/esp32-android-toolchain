<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_base">

    <!-- Toolbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:background="@color/bg_panel" android:paddingHorizontal="16dp" android:gravity="center_vertical">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Compiler Setup" android:textColor="@color/text_primary"
            android:textSize="16sp" android:fontFamily="monospace" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:padding="20dp" android:gravity="center_horizontal">

        <ImageView android:layout_width="80dp" android:layout_height="80dp"
            android:src="@drawable/ic_chip" app:tint="@color/cyan"
            android:contentDescription="ESP32"
            android:layout_marginTop="20dp" android:layout_marginBottom="20dp"/>

        <TextView android:id="@+id/tv_setup_status" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Ready to install compiler"
            android:textColor="@color/text_primary" android:textSize="14sp"
            android:gravity="center" android:layout_marginBottom="24dp"/>

        <Button android:id="@+id/btn_start_setup" android:layout_width="match_parent"
            android:layout_height="54dp" android:text="⬇ INSTALL COMPILER (~200MB)"
            android:backgroundTint="@color/cyan" android:textColor="#000"
            style="@style/Widget.MaterialComponents.Button" android:textStyle="bold"/>

        <ProgressBar android:id="@+id/setup_progress" android:layout_width="match_parent"
            android:layout_height="10dp" android:indeterminate="true" android:visibility="gone"
            android:progressTint="@color/cyan" android:layout_marginTop="16dp"/>

        <LinearLayout android:id="@+id/layout_setup_log" android:layout_width="match_parent"
            android:layout_height="0dp" android:layout_weight="1" android:orientation="vertical"
            android:background="@color/bg_void"
            android:layout_marginTop="8dp">
            <ScrollView android:id="@+id/scroll_setup_log" android:layout_width="match_parent"
                android:layout_height="0dp" android:layout_weight="1">
                <TextView android:id="@+id/tv_setup_log" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:padding="10dp"
                    android:fontFamily="monospace" android:textSize="11sp" android:textColor="@color/green"/>
            </ScrollView>
            <Button android:id="@+id/btn_copy_log" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="📋 Copy logs to clipboard"
                android:textColor="@color/text_secondary" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
