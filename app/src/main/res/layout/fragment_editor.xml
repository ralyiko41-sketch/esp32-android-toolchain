<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_panel"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_file_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="sketch_main"
            android:textColor="@color/cyan"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:ellipsize="start"
            android:singleLine="true" />

        <ImageButton android:id="@+id/btn_undo"     style="@style/ToolbarIconBtn" android:src="@drawable/ic_undo" />
        <ImageButton android:id="@+id/btn_redo"     style="@style/ToolbarIconBtn" android:src="@drawable/ic_redo" />
        <ImageButton android:id="@+id/btn_save"     style="@style/ToolbarIconBtn" android:src="@drawable/ic_save" />
        <ImageButton android:id="@+id/btn_navigator" style="@style/ToolbarIconBtn" android:src="@drawable/ic_menu" android:contentDescription="Navigator" />
        <ImageButton android:id="@+id/btn_new_file" style="@style/ToolbarIconBtn" android:src="@drawable/ic_add" />
    </LinearLayout>

    <!-- Board name bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="@color/bg_void"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/tv_board_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ESP32 Dev Module"
            android:textColor="@color/text_muted"
            android:fontFamily="monospace"
            android:textSize="11sp" />
        <TextView
            android:id="@+id/tv_compile_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Sora Code Editor -->
    <io.github.rosemoe.sora.widget.CodeEditor
        android:id="@+id/editor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Compile progress -->
    <ProgressBar
        android:id="@+id/compile_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:visibility="gone"
        android:indeterminate="true"
        android:progressTint="@color/cyan" />

    <!-- Symbol Bar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/symbol_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/bg_panel"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/bg_panel"
        android:padding="6dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_compile"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="COMPILE"
            android:textSize="12sp"
            android:fontFamily="monospace"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/cyan" />

        <Button
            android:id="@+id/btn_flash"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1.4"
            android:layout_marginHorizontal="4dp"
            android:text="⚡ FLASH"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:backgroundTint="@color/cyan"
            android:textColor="#000000"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/btn_monitor"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="MONITOR"
            android:textSize="11sp"
            android:fontFamily="monospace"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/text_secondary" />
    </LinearLayout>
</LinearLayout>
