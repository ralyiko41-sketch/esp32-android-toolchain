<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_base">
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:background="@color/bg_panel" android:paddingHorizontal="16dp" android:gravity="center_vertical">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Git Integration" android:textColor="@color/text_primary"
            android:textSize="16sp" android:fontFamily="monospace" android:textStyle="bold"/>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">
            <EditText android:id="@+id/et_remote" android:layout_width="match_parent" android:layout_height="44dp"
                android:hint="Remote URL (https://github.com/user/repo)" android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary" android:textSize="12sp" android:fontFamily="monospace"
                android:background="@color/bg_surface" android:paddingHorizontal="10dp"
                android:inputType="textUri" android:layout_marginBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                <EditText android:id="@+id/et_user" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:hint="Username" android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary" android:textSize="12sp"
                    android:background="@color/bg_surface" android:paddingHorizontal="10dp"
                    android:inputType="text" android:layout_marginEnd="8dp"/>
                <EditText android:id="@+id/et_branch" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:hint="Branch (main)" android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary" android:textSize="12sp"
                    android:background="@color/bg_surface" android:paddingHorizontal="10dp" android:inputType="text"/>
            </LinearLayout>
            <EditText android:id="@+id/et_token" android:layout_width="match_parent" android:layout_height="44dp"
                android:hint="GitHub Token (ghp_xxx)" android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary" android:textSize="12sp" android:fontFamily="monospace"
                android:background="@color/bg_surface" android:paddingHorizontal="10dp"
                android:inputType="textPassword" android:layout_marginBottom="12dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp">
                <Button android:id="@+id/btn_status" android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="Status" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="@color/cyan" android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btn_clone" android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="Clone" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="@color/cyan"/>
            </LinearLayout>
            <EditText android:id="@+id/et_commit_msg" android:layout_width="match_parent" android:layout_height="44dp"
                android:hint="Commit message..." android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary" android:textSize="13sp"
                android:background="@color/bg_surface" android:paddingHorizontal="10dp"
                android:inputType="text" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btn_push" android:layout_width="match_parent" android:layout_height="44dp"
                android:text="Commit + Push" android:backgroundTint="@color/cyan" android:textColor="#000"
                style="@style/Widget.MaterialComponents.Button" android:layout_marginBottom="12dp"/>
            <ProgressBar android:id="@+id/progress_git" android:layout_width="match_parent"
                android:layout_height="3dp" android:indeterminate="true" android:visibility="gone"
                android:progressTint="@color/cyan"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="OUTPUT" android:textColor="@color/text_muted" android:textSize="10sp" android:textAllCaps="true"/>
                <Button android:id="@+id/btn_clear_output" style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Clear" android:textColor="@color/text_muted" android:textSize="11sp"/>
            </LinearLayout>
            <ScrollView android:id="@+id/scroll_output" android:layout_width="match_parent" android:layout_height="180dp"
                android:background="@color/bg_void" android:padding="8dp">
                <TextView android:id="@+id/tv_output" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:fontFamily="monospace"
                    android:textSize="11sp" android:textColor="@color/green"/>
            </ScrollView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
