<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp"
    android:gravity="center_vertical">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="10dp">
        <TextView android:id="@+id/tv_lib_name" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/text_primary"
            android:textSize="13sp" android:fontFamily="monospace" android:textStyle="bold"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/tv_lib_author" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/text_muted" android:textSize="11sp"/>
            <TextView android:id="@+id/tv_lib_version" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_dim" android:textSize="11sp" android:fontFamily="monospace"/>
        </LinearLayout>
    </LinearLayout>
    <Button android:id="@+id/btn_install" android:layout_width="80dp" android:layout_height="32dp"
        android:text="Install" android:textSize="11sp" android:backgroundTint="@color/cyan"
        android:textColor="#000" style="@style/Widget.MaterialComponents.Button"/>
</LinearLayout>
