<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="20dp" android:background="@color/bg_panel">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Board Options" android:textColor="@color/cyan"
        android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="CPU Frequency" android:textColor="@color/text_muted" android:textSize="11sp"
        android:textAllCaps="true" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spinner_cpu_freq" android:layout_width="match_parent"
        android:layout_height="44dp" android:background="@color/bg_surface"
        android:entries="@array/cpu_frequencies" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Flash Frequency" android:textColor="@color/text_muted" android:textSize="11sp"
        android:textAllCaps="true" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spinner_flash_freq" android:layout_width="match_parent"
        android:layout_height="44dp" android:background="@color/bg_surface"
        android:entries="@array/flash_frequencies" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Flash Mode" android:textColor="@color/text_muted" android:textSize="11sp"
        android:textAllCaps="true" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spinner_flash_mode" android:layout_width="match_parent"
        android:layout_height="44dp" android:background="@color/bg_surface"
        android:entries="@array/flash_modes" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Partition Scheme" android:textColor="@color/text_muted" android:textSize="11sp"
        android:textAllCaps="true" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spinner_partitions" android:layout_width="match_parent"
        android:layout_height="44dp" android:background="@color/bg_surface"
        android:entries="@array/partition_schemes" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Core Debug Level" android:textColor="@color/text_muted" android:textSize="11sp"
        android:textAllCaps="true" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spinner_debug_level" android:layout_width="match_parent"
        android:layout_height="44dp" android:background="@color/bg_surface"
        android:entries="@array/core_debug_levels" android:layout_marginBottom="24dp"/>

    <Button android:id="@+id/btn_save_config" android:layout_width="match_parent"
        android:layout_height="48dp" android:text="APPLY CONFIGURATION"
        android:backgroundTint="@color/cyan" android:textColor="#000"
        style="@style/Widget.MaterialComponents.Button" android:textStyle="bold"/>

</LinearLayout>
