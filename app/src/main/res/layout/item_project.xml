<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="12dp"
    android:background="@drawable/card_bg" android:layout_marginBottom="8dp">

    <TextView android:id="@+id/tv_project_name" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Blink Project"
        android:textColor="@color/cyan" android:textSize="15sp" android:textStyle="bold"
        android:fontFamily="monospace"/>

    <TextView android:id="@+id/tv_project_info" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Created: 24/06/2026"
        android:textColor="@color/text_muted" android:textSize="11sp"
        android:layout_marginTop="2dp"/>

</LinearLayout>
