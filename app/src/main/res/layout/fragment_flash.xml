<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:background="@color/bg_panel" android:paddingHorizontal="16dp" android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="⚡  USB Flash" android:textColor="@color/text_primary"
            android:textSize="16sp" android:fontFamily="monospace" android:textStyle="bold" />
        <ImageButton android:id="@+id/btn_settings" style="@style/ToolbarIconBtn" android:src="@drawable/ic_settings" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">

            <!-- Compile status -->
            <TextView android:id="@+id/tv_compile_status"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="No firmware compiled yet"
                android:textColor="@color/text_secondary" android:textSize="13sp"
                android:padding="12dp" android:background="@drawable/card_bg" android:layout_marginBottom="10dp" />

            <!-- Device list header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="USB DEVICES" android:textColor="@color/text_muted"
                    android:textSize="11sp" android:letterSpacing="0.1" android:textAllCaps="true" />
                <Button android:id="@+id/btn_refresh" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content" android:layout_height="34dp"
                    android:text="Refresh" android:textSize="11sp" android:textColor="@color/cyan" />
            </LinearLayout>

            <!-- Device RecyclerView -->
            <TextView android:id="@+id/tv_empty_devices"
                android:layout_width="match_parent" android:layout_height="80dp"
                android:text="No USB device found.\nPlug in ESP32 via USB cable → tap Refresh"
                android:textColor="@color/text_muted" android:textSize="13sp"
                android:gravity="center" android:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_devices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="10dp" />

            <!-- Selected port -->
            <TextView android:id="@+id/tv_selected_port"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="No device selected" android:textColor="@color/text_muted"
                android:textSize="12sp" android:layout_marginBottom="12dp" />

            <!-- Flash progress -->
            <LinearLayout android:id="@+id/flash_progress_layout"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                <ProgressBar android:id="@+id/flash_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                    android:visibility="gone" android:progressTint="@color/green"
                    android:max="100" android:progress="0" />
                <TextView android:id="@+id/tv_flash_percent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0%" android:textColor="@color/green" android:textSize="12sp"
                    android:layout_marginStart="8dp" android:visibility="gone" android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Buttons -->
            <Button android:id="@+id/btn_compile_flash"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="⚙ COMPILE + FLASH" android:textSize="14sp" android:fontFamily="monospace"
                android:backgroundTint="@color/cyan" android:textColor="#000000"
                style="@style/Widget.MaterialComponents.Button" android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btn_flash"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="⚡ FLASH ONLY (use compiled binary)"
                android:textSize="13sp" android:fontFamily="monospace"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/cyan" android:layout_marginBottom="12dp" />

            <!-- Output log -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="OUTPUT" android:textColor="@color/text_muted"
                android:textSize="10sp" android:letterSpacing="0.1" android:textAllCaps="true"
                android:layout_marginBottom="4dp" />

            <ScrollView android:id="@+id/scroll_output"
                android:layout_width="match_parent" android:layout_height="200dp"
                android:background="@color/bg_void" android:padding="8dp">
                <TextView android:id="@+id/tv_output"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:fontFamily="monospace" android:textSize="11sp"
                    android:textColor="@color/green" android:lineSpacingExtra="2dp" />
            </ScrollView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
